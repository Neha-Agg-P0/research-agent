# Required — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended for cloud deployments (Vercel, Railway, etc.)
# Without these, the app falls back to Reddit's public API (blocked on cloud IPs)
# Create a free app at: https://www.reddit.com/prefs/apps  (choose "script" type)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
